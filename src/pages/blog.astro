---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Coming Soon | FersMath"
  description="The FERSmath blog is under construction. Our best man is on it — check back soon for articles on FERS, TSP, and Social Security."
>
  <main
    style="min-height: 100vh; display: flex; align-items: center; justify-content: center;
           background: linear-gradient(135deg, var(--color-primary-700) 0%, var(--color-primary-600) 60%, var(--color-teal-600) 100%);
           padding: 3rem 1.5rem;"
  >
    <div style="max-width: 560px; text-align: center;">
      <div
        style="width: 7rem; height: 7rem; margin: 0 auto 2rem; background-color: rgba(201,160,53,0.15);
               border: 1px solid rgba(201,160,53,0.3); border-radius: 50%; display: flex;
               align-items: center; justify-content: center; font-size: 3.5rem;"
      >
        👷
      </div>
      <span
        style="display: inline-block; background-color: rgba(255,255,255,0.08); color: var(--color-primary-200);
               font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
               padding: 0.3rem 0.9rem; border-radius: var(--radius-full); margin-bottom: 1rem;
               border: 1px solid rgba(255,255,255,0.15);"
      >
        Coming Soon
      </span>
      <h1
        style="font-family: var(--font-display); font-size: clamp(1.75rem, 5vw, 2.5rem); font-weight: 700;
               color: white; line-height: 1.25; margin: 0 0 1rem;"
      >
        We have our best man working on it.
      </h1>
      <p
        style="font-size: 1rem; color: var(--color-primary-100); line-height: 1.7; max-width: 460px;
               margin: 0 auto 2.5rem;"
      >
        The FERSmath blog is under construction. Check back soon for clear,
        unbiased writing on FERS, TSP, and Social Security.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a
          href="/calculators"
          style="background-color: var(--color-gold-400); color: var(--color-primary-700); font-weight: 600;
                 font-size: 1rem; padding: 0.875rem 2rem; border-radius: var(--radius-md); text-decoration: none;"
        >
          Browse Calculators
        </a>
        <a
          href="/"
          style="background-color: rgba(255,255,255,0.1); color: white; font-weight: 500; font-size: 1rem;
                 padding: 0.875rem 2rem; border-radius: var(--radius-md); text-decoration: none;
                 border: 1px solid rgba(255,255,255,0.2);"
        >
          Back to Home
        </a>
      </div>
    </div>
  </main>
</Layout>
